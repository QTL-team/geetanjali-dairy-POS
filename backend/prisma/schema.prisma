generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  businessName      String?
  phone             String?
  address           String?
  gstNumber         String?
  invoiceFooterText String?
  createdAt         DateTime @default(now())
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Product {
  id                    String                 @id @default(uuid())
  name                  String
  unit                  UnitType
  sellingPrice          Float
  availableStock        Float                  @default(0)
  reservedStock         Float                  @default(0)
  returnedStock         Float                  @default(0)
  lowStockThreshold     Float                  @default(10)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  description           String?
  gujaratiName          String?
  inventoryTransactions InventoryTransaction[]
  orderItems            OrderItem[]
}

model InventoryTransaction {
  id        String                   @id @default(uuid())
  productId String
  quantity  Float
  type      InventoryTransactionType
  remarks   String?
  createdAt DateTime                 @default(now())
  product   Product                  @relation(fields: [productId], references: [id])
}

model Order {
  id                String        @id @default(uuid())
  orderNumber       String        @unique
  customerId        String
  deliveryDate      DateTime
  deliveryAddress   String
  contactNumber     String
  notes             String?
  status            OrderStatus   @default(PENDING)
  totalAmount       Float         @default(0)
  paymentStatus     PaymentStatus @default(PENDING)
  isInvoiced        Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  workerSlipPrinted Boolean       @default(false)
  invoice           Invoice?
  customer          Customer      @relation(fields: [customerId], references: [id])
  items             OrderItem[]
  returns           OrderReturn[]
}

model OrderItem {
  id               String        @id @default(uuid())
  orderId          String
  productId        String
  quantity         Float
  returnedQuantity Float         @default(0)
  billedQuantity   Float         @default(0)
  unitPrice        Float
  totalPrice       Float
  order            Order         @relation(fields: [orderId], references: [id])
  product          Product       @relation(fields: [productId], references: [id])
  returns          OrderReturn[]
}

model Invoice {
  id            String           @id @default(uuid())
  invoiceNumber String           @unique
  orderId       String           @unique
  amount        Float
  status        InvoiceStatus    @default(DRAFT)
  generatedAt   DateTime         @default(now())
  balanceAmount Float            @default(0)
  paidAmount    Float            @default(0)
  order         Order            @relation(fields: [orderId], references: [id])
  payments      InvoicePayment[]
}

model InvoicePayment {
  id          String      @id @default(uuid())
  invoiceId   String
  amount      Float
  paidAt      DateTime    @default(now())
  method      String
  notes       String?
  paymentType PaymentType
  invoice     Invoice     @relation(fields: [invoiceId], references: [id])
}

model OrderReturn {
  id               String    @id @default(uuid())
  orderId          String
  orderItemId      String
  returnedQuantity Float
  remarks          String?
  createdAt        DateTime  @default(now())
  
  order            Order     @relation(fields: [orderId], references: [id])
  orderItem        OrderItem @relation(fields: [orderItemId], references: [id])
}

enum UnitType {
  KG
  LITER
  PIECE
}

enum InventoryTransactionType {
  ADD
  RESERVE
  RETURN
  ADJUSTMENT
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
}

enum PaymentType {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
}
